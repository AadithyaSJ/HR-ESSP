# HR Employee Self-Service Portal - Environment Variables Template
# Copy this file to .env and fill in your local/staging/production values
# NEVER commit .env file - it contains secrets!

# ==================== DATABASE ====================
DB_USER=springuser
DB_PASSWORD=spring123
DB_NAME=dot_solution
DB_HOST=172.26.25.122
DB_PORT=5432

# ==================== KEYCLOAK ====================
# Keycloak Admin Credentials
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin

# Keycloak Database
KC_DB_NAME=keycloak
KC_DB_USER=postgres
KC_DB_PASSWORD=postgres

# Keycloak Server
KC_SERVER_URL=http://localhost:8081
KC_REALM=hrportal
KC_CLIENT_ID=hrportal-web
KC_CLIENT_SECRET=change_me_in_production

# ==================== SPRING BOOT ====================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT Configuration
JWT_ISSUER=http://localhost:8081/realms/hrportal
JWT_AUDIENCE=hrportal-web
JWT_SECRET=your_jwt_secret_key_here

# ==================== AWS / S3 ====================
# For development, use MinIO (local S3-compatible)
# For production, use actual AWS credentials

# MinIO Credentials (Local Development)
MINIO_URL=http://localhost:9000
MINIO_BUCKET_NAME=hrportal
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# AWS Credentials (Production)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_SES_REGION=ap-south-1

# ==================== EMAIL / NOTIFICATIONS ====================
# AWS SES or SMTP
MAIL_FROM=noreply@hrportal.local
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password

# ==================== LOGGING ====================
LOGGING_LEVEL=INFO
LOGGING_LEVEL_COM_DOTSOLUTION=DEBUG

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== FRONTEND ====================
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_KC_SERVER_URL=http://localhost:8081
VITE_KC_REALM=hrportal
VITE_KC_CLIENT_ID=hrportal-web

# ==================== SECURITY ====================
# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Session Timeout (milliseconds)
SESSION_TIMEOUT_MS=1800000

# ==================== ACTUATOR / MONITORING ====================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
